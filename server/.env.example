# Hugging Face access token (required for STT + LLM calls).
# Create one at https://huggingface.co/settings/tokens
# Alternatively, you can leave this empty and paste the token into the Ayarlar (Settings)
# page in the app instead — either source works, this env var just avoids typing it each run.
HF_TOKEN=

# ElevenLabs API key (required for TTS — Turkish speech synthesis).
# Create one at https://elevenlabs.io/app/settings/api-keys
# Same rule as HF_TOKEN: can also be pasted into Ayarlar instead of set here.
ELEVENLABS_API_KEY=

# Port the backend listens on. The frontend dev server proxies /api and /ws here.
PORT=4000

# Postgres connection string (required). All scenarios/calls/settings live here instead of
# a local file, so data survives redeploys/restarts on any hosting platform.
# - Local dev: run a container — `docker run -d --name cex-postgres -e POSTGRES_PASSWORD=cex -e POSTGRES_DB=cex -p 5433:5432 postgres:16-alpine`
#   then use: postgres://postgres:cex@localhost:5433/cex
# - Hosted (free tier options): Neon (neon.tech) or Supabase (supabase.com) both give you a
#   ready-to-paste connection string from their dashboard.
DATABASE_URL=

# Set to "false" to disable SSL (only relevant for self-hosted/non-managed Postgres that
# doesn't support it). Auto-enabled for any non-localhost DATABASE_URL.
# PGSSL=false

# Secret used to sign login/register JWTs (required). Any long random string — generate one
# with `openssl rand -hex 32`. Changing this invalidates all existing logins.
JWT_SECRET=
